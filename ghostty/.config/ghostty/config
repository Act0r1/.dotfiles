font-family="Comic Mono"
# font-family="FiraCode Nerd Font
# -> ->
# theme=ChallengerDeep
# theme=Dracula
# theme=Github-Dark-Colorblind
# theme=Horizon
# theme=TokyoNight
theme=Catppuccin Mocha
selection-background = #4a5272
font-size=13
shell-integration = zsh

# keybindings (ctrl for Linux)
keybind = ctrl+g>r=reload_config
keybind = ctrl+g>x=close_surface
background-opacity = 0.95

quick-terminal-size=20%,40%
quick-terminal-position=top

keybind = alt+f=toggle_fullscreen
window-save-state = always

window-decoration=none
window-inherit-working-directory=true
working-directory=home
bell-features=system

window-padding-y = 0
window-padding-x = 0
background-blur=2

link-url = true

confirm-close-surface=false
custom-shader = ./shaders/cursor_smear.glsl
# custom-shader = ./shaders/retro-terminal.glsl
# custom-shader = ./shaders/kanagawa-phosphor.glsl
# custom-shader = ./shaders/statusline-nocturne.glsl
# custom-shader = shaders/cursor_frozen.glsl
# custom-shader = shaders/cursor_blaze.glsl
# custom-shader = shaders/WIP.glsl
# custom-shader = shaders/manga_slash.glsl
keybind = ctrl+g>n=new_window
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# tabs
keybind = ctrl+g>c=new_tab
keybind = ctrl+g>shift+l=next_tab
keybind = ctrl+g>shift+h=previous_tab
keybind = ctrl+g>comma=move_tab:-1
keybind = ctrl+g>period=move_tab:1

# quick tab switch
keybind = ctrl+g>1=goto_tab:1
keybind = ctrl+g>2=goto_tab:2
keybind = ctrl+g>3=goto_tab:3
keybind = ctrl+g>4=goto_tab:4
keybind = ctrl+g>5=goto_tab:5
keybind = ctrl+g>6=goto_tab:6
keybind = ctrl+g>7=goto_tab:7
keybind = ctrl+g>8=goto_tab:8
keybind = ctrl+g>9=goto_tab:9

# split
keybind = ctrl+g>\=new_split:right
keybind = ctrl+g>-=new_split:down

keybind = ctrl+g>j=goto_split:bottom
keybind = ctrl+g>k=goto_split:top
keybind = ctrl+g>h=goto_split:left
keybind = ctrl+g>l=goto_split:right

keybind = ctrl+g>z=toggle_split_zoom

keybind = ctrl+g>e=equalize_splits

# other
copy-on-select = clipboard
app-notifications = no-clipboard-copy
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = shift+enter=text:\x1b\r

# Mouse scroll speed
mouse-scroll-multiplier = 2
