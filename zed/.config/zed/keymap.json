[
    // ; -> : (как в nvim)
    {
        "context": "VimControl && !menu",
        "bindings": {
            ";": "command_palette::Toggle",
        },
    },

    // === Normal mode ===
    {
        "context": "vim_mode == normal",
        "bindings": {
            // Файлы и поиск (fzf-lua аналоги)
            "space f f": "file_finder::Toggle",
            "space f w": "pane::DeploySearch",
            "space f b": "tab_switcher::Toggle",

            // Окна / сплиты
            "space v": "pane::SplitRight",
            "space h": "pane::SplitDown",
            "space c w": "pane::CloseActiveItem",

            // Буферы
            "space ,": "pane::ActivatePreviousItem",
            "space .": "pane::ActivateNextItem",
            "space b d": "pane::CloseOtherItems",

            // Показать ошибку/диагностику (как vim.diagnostic.open_float)
            "space e": "editor::Hover",
            "space r n": "editor::Rename",
            "space c a": "editor::ToggleCodeActions",
            "space l d": "outline::Toggle",

            // Диагностика
            "] d": "editor::GoToDiagnostic",
            "[ d": "editor::GoToPreviousDiagnostic",

            // Файловое дерево
            "space j": "workspace::ToggleLeftDock",

            "g y": ["vim::PushObject", { "around": true }],

            "space s": "editor::SelectAllMatches",

            "space n": "editor::SelectNext",

            // Копировать путь файла
            "space p a": "workspace::CopyPath",

            // Join/split (treesj аналог)
            "space m": "editor::JoinLines",
        },
    },

    // === Visual mode ===
    {
        "context": "vim_mode == visual",
        "bindings": {
            // Перемещение строк
            "alt-j": "editor::MoveLineDown",
            "alt-k": "editor::MoveLineUp",
            "space n": "editor::SelectNext",
            "space a": "editor::SelectAllMatches",
        },
    },

    // === Insert mode ===
    {
        "context": "vim_mode == insert",
        "bindings": {
            "ctrl-x ctrl-o": "editor::ShowCompletions",
        },
    },

    {
        "context": "Workspace",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-j": "workspace::ActivatePaneDown",
        },
    },

    {
        "context": "Terminal",
        "bindings": {
            "ctrl-h": ["terminal::SendKeystroke", "ctrl-h"],
            "ctrl-l": ["terminal::SendKeystroke", "ctrl-l"],
            "ctrl-k": ["terminal::SendKeystroke", "ctrl-k"],
            "ctrl-j": ["terminal::SendKeystroke", "ctrl-j"],
        },
    },

    // === Dock (file tree) — vim навигация ===
    {
        "context": "Dock",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-j": "workspace::ActivatePaneDown",
        },
    },
]
